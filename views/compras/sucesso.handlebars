<div class="max-w-2xl mx-auto">
    <div class="bg-white border rounded-2xl p-8 shadow-sm text-center">
        <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-4xl">✅</span>
        </div>
        
        <h2 class="text-2xl font-black text-slate-800 tracking-tight">Compra Confirmada!</h2>
        <p class="text-slate-500 text-sm mt-1">Seu pedido foi processado com sucesso e encaminhado para distribuição.</p>
        
        <div class="mt-6 bg-slate-50 rounded-xl p-4 text-left space-y-2">
            <div class="flex justify-between text-xs">
                <span class="font-bold text-slate-500">Código do Pedido:</span>
                <span class="font-mono font-bold text-slate-800">#{{compra.nf_id}}</span>
            </div>
            <div class="flex justify-between text-xs">
                <span class="font-bold text-slate-500">Data:</span>
                <span class="font-medium text-slate-700">{{formatDate compra.data_compra}}</span>
            </div>
            <div class="flex justify-between text-xs">
                <span class="font-bold text-slate-500">Cliente:</span>
                <span class="font-medium text-slate-700">{{compra.nome_cliente}}</span>
            </div>
            <div class="flex justify-between text-xs border-t pt-2">
                <span class="font-bold text-slate-500">Total:</span>
                <span class="font-black text-emerald-600 text-sm">R$ {{ compra.preco}}</span>
            </div>
        </div>

        <div class="mt-6">
            <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3">Itens do Pedido</h4>
            <div class="space-y-2">
                {{#each items}}
                <div class="flex items-center justify-between bg-white border rounded-xl p-3 text-xs">
                    <div class="flex items-center gap-3">
                        <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/{{this.numero_pokedex}}.png" 
                             onerror="this.src='https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/{{this.numero_pokedex}}.png'"
                             class="w-10 h-10 object-contain">
                        <div>
                            <p class="font-bold text-slate-800">{{this.nome_pokemon}}</p>
                            <p class="text-slate-400">{{this.quantidade}}x R$ {{ this.preco_unitario}}</p>
                        </div>
                    </div>
                    <span class="font-black text-emerald-600">R$ {{ multiply this.preco_unitario this.quantidade}}</span>
                </div>
                {{/each}}
            </div>
        </div>

        <div class="mt-8 flex gap-3 justify-center">
            <a href="/pokemon" class="bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs px-6 py-2.5 rounded-xl transition shadow-sm">
                📦 Continuar Comprando
            </a>
            <a href="/compras/historico" class="border border-slate-300 text-slate-600 hover:bg-slate-50 font-bold text-xs px-6 py-2.5 rounded-xl transition">
                📋 Ver Histórico
            </a>
        </div>
    </div>
</div>