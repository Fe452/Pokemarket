<div class="grid grid-cols-3 gap-6 items-start">
    <div id="cart-items-list" class="col-span-2 bg-white border rounded-2xl p-4 shadow-sm divide-y">
        {{#if cart.length}}
            {{#each cart}}
            <div class="flex items-center justify-between py-4 first:pt-0 last:pb-0 text-xs">
                <div class="flex items-center gap-3">
                    <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/{{this.numero_pokedex}}.png" 
                         onerror="this.src='https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/{{this.numero_pokedex}}.png'"
                         class="w-12 h-12 bg-slate-50 border rounded-xl p-1">
                    <div>
                        <div class="flex items-center gap-2">
                            <h4 class="font-black text-slate-800">{{this.nome_pokemon}}</h4>
                            <span class="type-badge type-{{this.tipos}}" style="font-size: 8px; padding: 1px 6px;"> {{this.tipos}}</span>
                        </div>
                        <p class="text-slate-400 font-medium mt-0.5">Preço unitário: R$ {{ this.preco_unitario}}</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-6">
                    <div class="text-center">
                        <span class="block text-[10px] font-bold text-slate-400 uppercase">Qtd Comprada</span>
                        <span class="font-black text-slate-700 bg-slate-100 px-2 py-0.5 rounded border mt-0.5 inline-block">{{this.quantidade}} un</span>
                    </div>
                    <div class="text-right w-24">
                        <span class="block text-[10px] font-bold text-slate-400 uppercase">Subtotal</span>
                        <span class="font-black text-emerald-600">R$ {{multiply this.preco_unitario this.quantidade}}</span>
                    </div>
                    <form action="/compras/carrinho/remover" method="POST" class="inline">
    <input type="hidden" name="pokemon_id" value="{{this.pokemon_id}}">
    <button type="submit" class="text-rose-500 hover:text-rose-700 font-bold transition pl-2">
        ✕
    </button>
</form>
                </div>
            </div>
            {{/each}}
        {{else}}
            <div class="text-center py-12 text-slate-400 font-medium text-xs">
                🛒 Seu carrinho de lotes comercial está vazio no momento.
            </div>
        {{/if}}
    </div>
    <div class="bg-white border rounded-2xl p-5 shadow-sm space-y-4">
        <h3 class="text-xs font-black text-slate-800 border-b pb-2 uppercase tracking-wide">Sumário de Saída</h3>
        <div class="space-y-2 text-xs font-medium text-slate-500">
            <div class="flex justify-between"><span>Espécies:</span><span id="checkout-species-qty" class="font-bold text-slate-700">{{cart.length}}</span></div>
            <div class="flex justify-between"><span>Unidades:</span><span id="checkout-items-qty" class="font-bold text-slate-700">{{totalItems}} un</span></div>
            <div class="flex justify-between border-t pt-3 text-sm font-black text-slate-800"><span>Total:</span><span id="checkout-total-price" class="text-emerald-600"> {{formatCurrency total}}</span></div>
        </div>
        <form action="/compras/finalizar" method="POST">
            <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-2.5 rounded-xl transition text-xs shadow-md" {{#unless cart.length}}disabled{{/unless}}>
                Confirmar e Faturar Saída
            </button>
        </form>
    </div>
</div>